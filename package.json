{
	"name": "ts-hajime",
	"description": "Delightfully bootstraps TypeScript npm libraries.",
	"version": "0.4.23",
	"scripts": {
		"setup": "rm -rf node_modules && npm i && husky",
		"prepublishOnly": "npm run build",
		"build": "tsup",
		"test": "vitest",
		"lint": "npx @biomejs/biome check --write",
		"npx": "tsx src",
		"update": "npx npm-check-updates -u && npm i"
	},
	"bin": {
		"ts-hajime": "./bin/index.cjs"
	},
	"files": [
		"./bin",
		"./template",
		"./template/.gitignore"
	],
	"lint-staged": {
		"*": [
			"npm run lint"
		]
	},
	"type": "module",
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@clack/prompts": "^1.2.0",
		"@types/fs-extra": "^11.0.4",
		"@types/validate-npm-package-name": "^4.0.2",
		"@vitest/coverage-v8": "^4.1.5",
		"execa": "^9.6.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"validate-npm-package-name": "^7.0.2",
		"vitest": "^4.1.5"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tylim88/ts-hajime.git"
	},
	"bugs": {
		"url": "https://github.com/tylim88/ts-hajime/issues"
	},
	"author": "tylim",
	"license": "MIT",
	"keywords": [
		"typescript",
		"bootstrap",
		"library",
		"starter",
		"scaffold",
		"template"
	]
}
